{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "sync": {
      "dependsOn": ["^sync"]
    },
    "test": {
      "cache": true,
      "dependsOn": ["^build"]
    },
    "test:cov": {
      "cache": true,
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "cache": true,
      "dependsOn": ["^build", "^test:e2e"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    }
  }
}
