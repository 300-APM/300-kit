{
  "name": "@300apm/nestjs-core",
  "version": "0.0.1",
  "description": "Core NestJS utilities for 300-kit applications",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./database/base.entity": {
      "types": "./dist/database/base.entity.d.ts",
      "import": "./dist/database/base.entity.js"
    },
    "./database/base.repository": {
      "types": "./dist/database/base.repository.d.ts",
      "import": "./dist/database/base.repository.js"
    },
    "./database/database.module": {
      "types": "./dist/database/database.module.d.ts",
      "import": "./dist/database/database.module.js"
    },
    "./database/mikro-orm.config": {
      "types": "./dist/database/mikro-orm.config.d.ts",
      "import": "./dist/database/mikro-orm.config.js"
    },
    "./tenants/tenant.entity": {
      "types": "./dist/tenants/tenant.entity.d.ts",
      "import": "./dist/tenants/tenant.entity.js"
    },
    "./tenants/tenant-aware.entity": {
      "types": "./dist/tenants/tenant-aware.entity.d.ts",
      "import": "./dist/tenants/tenant-aware.entity.js"
    },
    "./tenants/tenant.guard": {
      "types": "./dist/tenants/tenant.guard.d.ts",
      "import": "./dist/tenants/tenant.guard.js"
    },
    "./tenants/tenant.middleware": {
      "types": "./dist/tenants/tenant.middleware.d.ts",
      "import": "./dist/tenants/tenant.middleware.js"
    },
    "./tenants/tenant.repository": {
      "types": "./dist/tenants/tenant.repository.d.ts",
      "import": "./dist/tenants/tenant.repository.js"
    },
    "./tenants/tenants.module": {
      "types": "./dist/tenants/tenants.module.d.ts",
      "import": "./dist/tenants/tenants.module.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mikro-orm/core": "catalog:",
    "@mikro-orm/decorators": "catalog:",
    "@mikro-orm/migrations": "catalog:",
    "@mikro-orm/nestjs": "catalog:",
    "@mikro-orm/postgresql": "catalog:",
    "@mikro-orm/seeder": "catalog:",
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "uuidv7": "catalog:"
  },
  "devDependencies": {
    "@300apm/tsconfig": "workspace:*",
    "@swc/core": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "unplugin-swc": "catalog:",
    "vitest": "catalog:"
  }
}
