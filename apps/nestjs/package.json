    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@300apm/tsconfig": "workspace:*",
    "@nestjs/cli": "^11.0.9",
    "@nestjs/testing": "^11.1.3",
    "@swc/core": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "unplugin-swc": "catalog:",
    "vitest": "catalog:"
  }
}
